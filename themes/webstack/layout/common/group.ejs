<div class="category-section">
<h4 class="text-gray" id="<%= e.name.replace(/[\s]+/g, '-') %>"><i class="linecons-tag" style="margin-right: 7px;"></i><%= e.name %></h4>
<div class="row bookmark-grid">
  <% menus.forEach(function(menu, index) { %>
  <div class="col-sm-3 bookmark-item" data-index="<%= index %>">
    <div class="xe-widget xe-conversations box2 label-info bookmark-card" onclick="window.open('<%= url_for(menu.url) %>', '_blank')" data-toggle="tooltip" data-placement="bottom" title="<%= menu.description %>" data-original-title="<%= url_for(menu.url) %>" data-category="<%= e.name %>" data-name="<%= menu.name %>" <% if (menu.tags) { %>data-tags="<%= Array.isArray(menu.tags) ? menu.tags.join(',') : menu.tags %>"<% } %>>
      <div class="xe-comment-entry">
        <a class="xe-user-img">
          <%
            var _imgSrc, _imgFallback;
            try {
              var _domain = new URL(menu.url).hostname;
              var _ddg = 'https://icons.duckduckgo.com/ip3/' + _domain + '.ico';
              var _isPlaceholder = !menu.img || menu.img === '/images/favicon.ico';
              if (_isPlaceholder) {
                _imgSrc = _ddg;
                _imgFallback = url_for('/images/favicon.ico');
              } else {
                _imgSrc = url_for(menu.img);
                _imgFallback = _ddg;
              }
            } catch(e) {
              _imgSrc = menu.img ? url_for(menu.img) : url_for('/images/favicon.ico');
              _imgFallback = url_for('/images/favicon.ico');
            }
          %>
          <img data-src="<%= _imgSrc %>" class="lozad img-circle" width="50" alt="<%= menu.name %>"
               onerror="if(!this._fb){this._fb=true;this.src='<%= _imgFallback %>';}">
        </a>
        <div class="xe-comment">
          <div class="xe-user-name-fixed">
            <a href="#" class="xe-user-name overflowClip_1">
              <strong><%= menu.name %></strong>
            </a>
          </div>
          <% if (menu.tags && menu.tags.length > 0) { %>
          <div class="bookmark-tags">
            <% const tags = Array.isArray(menu.tags) ? menu.tags : [menu.tags]; %>
            <% tags.forEach(function(tag, tagIndex) { %>
              <span class="tag-item"><%= tag %></span>
            <% }) %>
          </div>
          <% } %>
          <div class="xe-comment-description">
            <p class="overflowClip_2"><%= menu.description %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
</div>
</div>
<br />
